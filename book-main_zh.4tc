\doTocEntry\tocsubsection{8.2.4}{\csname a:TocLink\endcsname{15}{x15-2690008.2.4}{QQ2-15-419}{优化策略}}{570}\relax 
\doTocEntry\toclof{8.8}{\csname a:TocLink\endcsname{15}{x15-269001r8}{}{\ignorespaces \small \textbf  {DINO 流水线。} 为每个输入计算 学生特征和教师特征。目标是 尝试通过将两组特征投影到高维 概率单纯形并计算交叉熵损失， 使学生特征与教师特征对齐。值得注意的是， 由于“停止梯度”（stop-grad），梯度仅 相对于\textit  {学生参数的输出}进行计算。}}{figure}\relax 
\doTocEntry\tocparagraph{}{\csname a:TocLink\endcsname{15}{x15-270000}{QQ2-15-421}{优化 DINO。}}{573}\relax 
\doTocEntry\toclof{8.9}{\csname a:TocLink\endcsname{15}{x15-270005r9}{}{\ignorespaces \small \textbf  {SimDINO 流水线。} 这里，与 \Cref  {fig:dino_pipeline} 中的 DINO 流水线相反，损失是 直接在特征上计算的，不需要进一步的 操作。这省去了几个大矩阵的 参数并简化了流水线，同时使其 训练更加稳定。}}{figure}\relax 
\doTocEntry\tocparagraph{}{\csname a:TocLink\endcsname{15}{x15-271000}{QQ2-15-423}{优化 SimDINO。}}{577}\relax 
