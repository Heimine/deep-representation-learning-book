\doTocEntry\tocchapter{1}{\csname a:TocLink\endcsname{8}{x8-180001}{QQ2-8-23}{关于智能的非正式引言}}{3}\relax 
\doTocEntry\tocsection{1.1}{\csname a:TocLink\endcsname{8}{x8-190001.1}{QQ2-8-24}{智能、控制论与人工智能}}{3}\relax 
\doTocEntry\tocparagraph{}{\csname a:TocLink\endcsname{8}{x8-20000}{QQ2-8-25}{智能的出现与进化。}}{4}\relax 
\doTocEntry\toclof{1.1}{\csname a:TocLink\endcsname{8}{x8-20003r1}{}{\ignorespaces 系统发育智能的进化：外部世界的记忆或知识 通过DNA进行编码和传递（左），并 从DNA解码为RNA再到蛋白质。在生命进化的早期阶段 （右），智能在物种层面上通过（随机的）基因突变和 自然选择——“适者生存”——来发展记忆或知识， 这可以被视为强化学习的一种原始形式。}}{figure}\relax 
\doTocEntry\toclof{1.2}{\csname a:TocLink\endcsname{8}{x8-20004r2}{}{\ignorespaces 生命的进化，从今天所有生命的祖先 （LUCA——最后广泛共同祖先），一种生活在35至43亿年前的类似单细胞的 生物 \cite {moody2024nature}，到大约5.5亿年前在蠕虫类物种中 出现的第一个神经系统（中） \cite {wang2025preservation}，再到大约5.3亿年前 寒武纪时期的生命形式大爆发（右）。}}{figure}\relax 
\doTocEntry\tocparagraph{}{\csname a:TocLink\endcsname{8}{x8-21000}{QQ2-8-28}{人类智能的进化。}}{10}\relax 
\doTocEntry\toclof{1.3}{\csname a:TocLink\endcsname{8}{x8-21001r3}{}{\ignorespaces 口头交流和口语（7万至3万年前）、 书面语言（约公元前3000年） \cite {schmandt2014evolution}以及抽象数学 （约公元前500至300年）\cite {heath1956thirteen}的发展标志着 人类智能进化中的三个关键里程碑。}}{figure}\relax 
\doTocEntry\tocparagraph{}{\csname a:TocLink\endcsname{8}{x8-22000}{QQ2-8-30}{机器智能的起源——控制论。}}{13}\relax 
\doTocEntry\toclof{1.4}{\csname a:TocLink\endcsname{8}{x8-22001r4}{}{\ignorespaces 诺伯特·维纳的著作《控制论》（1948年） \cite {Wiener-Cybernetics-1948}（左）及其第二版 （1961年）\cite {Wiener-Cybernetics-1961}（右）。}}{figure}\relax 
\doTocEntry\toclof{1.5}{\csname a:TocLink\endcsname{8}{x8-22004r5}{}{\ignorespaces 智能理论和计算基础的先驱： 诺伯特·维纳（控制论和控制 理论）、克劳德·香农（信息论）、约翰·冯·诺依曼 （博弈论）和艾伦·图灵（计算理论）。}}{figure}\relax 
